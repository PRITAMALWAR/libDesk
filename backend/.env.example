# Use 5001 to match the Expo app default (see store.ts / CalendarScreen resolveApiUrl).
PORT=5001
# Preferred name (also accepts MONGO_URI for older .env files)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/library_db?retryWrites=true&w=majority
ADMIN_USERNAME=
ADMIN_PIN=
ADMIN_MOBILE=0000000000
JWT_SECRET=change_me_attendance_secret
AUTH_JWT_SECRET=change_me_auth_secret
LIBRARY_ID=library-main

